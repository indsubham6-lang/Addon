{
  "manifest_version": 3,
  "name": "Linkumori(Clean URLs)",
  "version": "26.0",
  "author": "Subham_Mahesh",
  "description": "__MSG_extension_description__",
  "default_locale": "en",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "linkumori-addon-official@ClearURLs",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "img/icon16.png",
    "19": "img/icon19.png",
    "20": "img/icon20.png",
    "24": "img/icon24.png",
    "30": "img/icon30.png",
    "32": "img/icon32.png",
    "38": "img/icon38.png",
    "48": "img/icon48.png",
    "64": "img/icon64.png",
    "96": "img/icon96.png",
    "128": "img/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icon16.png",
      "19": "img/icon19.png",
      "20": "img/icon20.png",
      "24": "img/icon24.png",
      "30": "img/icon30.png",
      "32": "img/icon32.png",
      "38": "img/icon38.png",
      "48": "img/icon48.png",
      "64": "img/icon64.png",
      "96": "img/icon96.png",
      "128": "img/icon128.png"
    },
    "default_title": "Linkumori",
    "default_popup": "html/popup.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "contextMenus",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "tabs",
    "downloads",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "core_js/message_handler.js",
      "external_js/IP-Ranger.js",
      "external_js/sha256.js",
      "core_js/tools.js",
      "external_js/light-punycode.js",
      "external_js/publicsuffixlist.js",
      "core_js/badgedHandler.js",
      "core_js/pureCleaning.js",
      "core_js/context_menu.js",
      "core_js/historyListener.js",
      "clearurls.js",
      "core_js/storage.js",
      "core_js/content_script_manager.js",
      "core_js/watchdog.js",
      "core_js/eTagFilter.js",
      "external_js/decode-uri-component.js",
      "external_js/linkumori-i18n.js",
      "core_js/consent_config.js"
    ]
  },
  "options_ui": {
    "page": "html/settings.html",
    "open_in_tab": true
  }
}
